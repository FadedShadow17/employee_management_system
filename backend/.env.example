PORT=5000
NODE_ENV=development

# Example (Atlas): include the '/ems' database at the end of the host
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/ems?retryWrites=true&w=majority
# Optional: explicitly set DB name (defaults to 'ems')
MONGODB_DB_NAME=ems

# Authentication
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Field-Level Encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In production, use a Key Management Service (AWS KMS, HashiCorp Vault)
ENCRYPTION_KEY=your_64_hex_character_encryption_key_here
